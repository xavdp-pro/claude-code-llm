# Copy to .env and fill in your keys
# Ollama Cloud: https://ollama.com/settings/keys
OLLAMA_API_KEY=your-ollama-cloud-key
# OpenRouter: https://openrouter.ai/keys (needed for or-* models)
OPENROUTER_API_KEY=your-openrouter-key

# LiteLLM (Anthropic-compatible gateway)
LITELLM_PORT=4000
LITELLM_BIND=127.0.0.1

# Optional HTTP bridge for headless inject / SSE
CLAUDE_BRIDGE_PORT=4100
CLAUDE_BRIDGE_BIND=127.0.0.1
CLAUDE_WS_BASE=

# Claude Code → LiteLLM
ANTHROPIC_BASE_URL=http://127.0.0.1:4000
ANTHROPIC_AUTH_TOKEN=sk-claude-bridge-local
ANTHROPIC_MODEL=minimax-m3
ANTHROPIC_SMALL_FAST_MODEL=gpt-oss-20b
CLAUDE_VISION_MODEL=minimax-m3
